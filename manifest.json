{
  "manifest_version": 3,
  "name": "HST Gross-Up for Amazon.ca",
  "version": "1.0.0",
  "description": "Adds 13% Ontario HST to prices on Amazon.ca, so the price you see reflects what you'll actually pay at checkout.",
  "homepage_url": "https://github.com/perryfardella/amazon-ca-hst-gross-up",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.ca/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
